{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "claude-sync: sync CLAUDE.md files",
            "type": "shell",
            "command": "${workspaceFolder}/.claude-sync/sync.sh",
            "runOptions": {
                "runOn": "folderOpen"
            },
            "presentation": {
                "reveal": "silent",
                "panel": "dedicated"
            },
            "problemMatcher": []
        },
        {
            "label": "claude-sync: watch for new CLAUDE.md files",
            "type": "shell",
            "command": "${workspaceFolder}/.claude-sync/watch.sh",
            "isBackground": true,
            "runOptions": {
                "runOn": "folderOpen"
            },
            "presentation": {
                "reveal": "silent",
                "panel": "dedicated"
            },
            "problemMatcher": {
                "pattern": {
                    "regexp": "^(.*)$",
                    "message": 1
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^\\[claude-sync\\] watching",
                    "endsPattern": "^\\[claude-sync\\] watching"
                }
            }
        }
    ]
}
